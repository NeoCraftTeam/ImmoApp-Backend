APP_NAME=keyhome
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=testing
DB_USERNAME=gitlab
DB_PASSWORD=test_pass

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=array

# Redis - use TLS (rediss://) in production or ensure Docker-internal only
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

MAIL_MAILER=log

SCOUT_DRIVER=null

MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# OAuth Configuration (Laravel Socialite)
# Google - https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/api/v1/auth/oauth/google/callback

# Facebook - https://developers.facebook.com/
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=${APP_URL}/api/v1/auth/oauth/facebook/callback

# Apple - https://developer.apple.com/
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=${APP_URL}/api/v1/auth/oauth/apple/callback

# Clerk - https://dashboard.clerk.com/
# The publishable key is used to derive the JWKS URL automatically.
# Set CLERK_JWKS_URL explicitly if you change Clerk instances/domains.
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=
# CLERK_JWKS_URL example: https://your-instance.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_...

EMAIL_VERIFY_CALLBACK=http://localhost
EMAIL_CALLBACK_URL=http://localhost
FRONTEND_URL=http://localhost:3000

L5_SWAGGER_GENERATE_ALWAYS=false
SANCTUM_STATEFUL_DOMAINS=localhost
SANCTUM_TOKEN_PREFIX=kh_

# Comma-separated list of trusted proxy IPs or CIDR ranges (e.g. 10.0.0.0/8)
# Set to * only if behind a single fully trusted reverse proxy
TRUSTED_PROXIES=127.0.0.1

TELESCOPE_ENABLED=false
DB_SSLMODE=prefer

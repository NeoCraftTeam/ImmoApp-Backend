{
  "expo": {
    "name": "KeyHome Owner",
    "slug": "keyhome-owner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "keyhome-owner",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "cm.neocraft.keyhome.owner",
      "supportsTablet": true,
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png",
        "tinted": "./assets/icon-tinted.png"
      },
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsArbitraryLoadsInWebContent": false,
          "NSExceptionDomains": {
            "keyhome.neocraft.dev": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionRequiresForwardSecrecy": true
            },
            "neocraft.dev": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSExceptionRequiresForwardSecrecy": true
            }
          }
        },
        "NSCameraUsageDescription": "KeyHome utilise la caméra pour ajouter des photos à vos annonces immobilières.",
        "NSPhotoLibraryUsageDescription": "KeyHome accède à vos photos pour les ajouter à vos annonces immobilières.",
        "NSLocationWhenInUseUsageDescription": "KeyHome utilise votre position pour localiser vos biens immobiliers sur la carte.",
        "NSFaceIDUsageDescription": "KeyHome utilise Face ID pour sécuriser l'accès à votre espace propriétaire."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "cm.neocraft.keyhome.bailleur",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "keyhome-owner"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "aa2a861b-6ae4-481a-bc53-0fdf73421cb4"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "KeyHome accède à vos photos pour les ajouter à vos annonces.",
          "cameraPermission": "KeyHome utilise la caméra pour photographier vos biens."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "KeyHome utilise votre position pour localiser vos biens."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#10b981"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "KeyHome utilise Face ID pour sécuriser votre espace propriétaire."
        }
      ],
      "expo-splash-screen",
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "fr",
              "en"
            ],
            "android": [
              "fr",
              "en"
            ]
          }
        }
      ]
    ]
  }
}

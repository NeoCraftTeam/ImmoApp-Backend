# ============================================================
# PREPROD Environment — /opt/keyhome-preprod/.env
# ============================================================
# Les services infra (DB, Redis, Meilisearch) sont PARTAGÉS
# avec la prod. Seuls app, worker, web sont dupliqués.
#
# DB_HOST / REDIS_HOST / MEILISEARCH_HOST pointent vers les
# containers de production via le réseau Docker partagé.
# L'isolation des données se fait par DB_DATABASE, REDIS_PREFIX,
# et SCOUT_PREFIX.
# ============================================================

# --- Docker Compose ---
COMPOSE_PREFIX=keyhome-preprod
WEB_PORT=9091
APP_IMAGE=registry.gitlab.com/neocraft/projets/keyhome/backend/app:preprod

# --- Application ---
APP_NAME="KeyHome Preprod"
APP_ENV=staging
APP_KEY=
APP_DEBUG=true
APP_URL=https://preprod-api.keyhome.neocraft.dev

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (même PostgreSQL que prod, DB différente) ---
DB_CONNECTION=pgsql
DB_HOST=keyhome-prod-db
DB_PORT=5432
DB_DATABASE=keyhome_preprod
DB_USERNAME=cedrick
DB_PASSWORD=CHANGEZ_MOI_meme_que_prod

# --- Session ---
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# --- Services ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
REDIS_HOST=keyhome-prod-redis
REDIS_PREFIX=keyhome_preprod_database_

# --- Mail (utilisez mailtrap ou log en preprod) ---
MAIL_MAILER=log

# --- Search (même Meilisearch que prod, prefix différent) ---
SCOUT_DRIVER=meilisearch
SCOUT_PREFIX=preprod_
MEILISEARCH_HOST=http://keyhome-prod-meilisearch:7700
MEILISEARCH_KEY=CHANGEZ_MOI_meme_que_prod

# --- Payments (sandbox en preprod) ---
FEDAPAY_PUBLIC_KEY=
FEDAPAY_SECRET_KEY=
FEDAPAY_ENVIRONMENT=sandbox

# --- OAuth (utilisez les mêmes ou des clés de test) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=${APP_URL}/api/v1/auth/oauth/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=${APP_URL}/api/v1/auth/oauth/facebook/callback

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=${APP_URL}/api/v1/auth/oauth/apple/callback

# --- Clerk (utilisez les clés de test ou une instance séparée) ---
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=
CLERK_WEBHOOK_SECRET=whsec_...

# --- URLs ---
EMAIL_VERIFY_CALLBACK=https://preprod.keyhome.app
EMAIL_CALLBACK_URL=https://preprod.keyhome.app
FRONTEND_URL=https://preprod.keyhome.app

L5_SWAGGER_GENERATE_ALWAYS=false
SANCTUM_STATEFUL_DOMAINS=preprod.keyhome.app,preprod-api.keyhome.neocraft.dev

# --- Monitoring (optionnel en preprod) ---
# NIGHTWATCH_TOKEN=
# GRAFANA_PASSWORD=admin
